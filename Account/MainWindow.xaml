<Window x:Class="Account.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:local="clr-namespace:Account"
        mc:Ignorable="d"
        Title="Account" Height="450" Width="800"  WindowState="Maximized"   Loaded="Window_Loaded" >
    
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- 左侧侧边栏：宽度自适应（支持折叠） -->
            <ColumnDefinition Width="130"/>
            <!-- 右侧主体内容区 -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 【左侧导航栏】 -->
        <!-- SelectionChanged 事件用来监听用户点击了哪个菜单项 -->
        <hc:SideMenu Grid.Column="0" 
                     Name="MainMenu"
                     SelectionChanged="SideMenu_SelectionChanged"
                     MinWidth="200"
                     Background="{DynamicResource RegionBrush}" Grid.ColumnSpan="2" Margin="0,74,0,0">

            <!-- 侧边栏顶部：一般放 Logo 或用户信息 -->
            <hc:SideMenu.Header>
                <!-- 直接在这里写死布局，注意给足高度和显眼的颜色 -->
                <Border Height="80" BorderBrush="Red" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!--<Image Source="logo.png" Width="30" Height="30" Margin="0,0,10,0"/>-->
                        <TextBlock Text="管理系统" FontSize="18" Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </StackPanel>
                </Border>
            </hc:SideMenu.Header>

            <!-- 菜单项列表 -->
            <!-- ImageGeometry 可以直接绑定内置的几何图形，比如从 HandyControl 资源中找，或者自己写 PathData -->
            <hc:SideMenuItem Header="支出详情" CommandParameter="Expend" IsSelected="True" >
                <hc:SideMenuItem.Icon>
                    <!-- 嵌入传统的图片控件，建议固定宽高以防变形 -->
                    <Image Source="/Images/支出详情.png" 
               Width="130" 
               Height="40"
               Stretch="Uniform"/>
                </hc:SideMenuItem.Icon>
            </hc:SideMenuItem>

            <hc:SideMenuItem Header="收入详情" CommandParameter="Income">
                <hc:SideMenuItem.Icon>
                    <!-- 嵌入传统的图片控件，建议固定宽高以防变形 -->
                    <Image Source="/Images/收入详情.png" 
Width="130" 
Height="40"
Stretch="Uniform"/>
                </hc:SideMenuItem.Icon>
            </hc:SideMenuItem>
            <hc:SideMenuItem Header="收入类别" CommandParameter="IncomeCategory">
                <hc:SideMenuItem.Icon>
                    <!-- 嵌入传统的图片控件，建议固定宽高以防变形 -->
                    <Image Source="/Images/收入类别.png" 
Width="130" 
Height="40"
Stretch="Uniform"/>
                </hc:SideMenuItem.Icon>
            </hc:SideMenuItem>
            <hc:SideMenuItem Visibility="Collapsed" Header="其他" CommandParameter="Other">
                <!--<hc:SideMenuItem.Icon>
                    --><!-- 嵌入传统的图片控件，建议固定宽高以防变形 --><!--
                    <Image Source="/Images/收入详情.png" 
Width="130" 
Height="40"
Stretch="Uniform"/>
                </hc:SideMenuItem.Icon>-->
            </hc:SideMenuItem>
        </hc:SideMenu>
        <!--<hc:SideMenu Grid.ColumnSpan="2">
            -->
