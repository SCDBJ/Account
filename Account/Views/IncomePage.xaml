<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Account.Views"
      xmlns:hc="https://handyorg.github.io/handycontrol" x:Class="Account.Views.IncomePage"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="IncomePage">

    <Grid>
        <Label Content="开始日期" HorizontalAlignment="Left" Margin="26,37,0,0" VerticalAlignment="Top" FontSize="16" Height="30"/>
        <hc:DatePicker Name="startDatePicker" HorizontalAlignment="Left" Margin="130,37,0,0" FontSize="16" VerticalAlignment="Top" Background="#33a5b0" Foreground="White" FontWeight="Bold" Width="125" Height="30"/>
        <Label Content="结束日期" HorizontalAlignment="Left" Margin="265,37,0,0" VerticalAlignment="Top" FontSize="16" Height="30"/>
        <hc:DatePicker Name="endDatePicker" HorizontalAlignment="Left" Margin="365,37,0,0" VerticalAlignment="Top" FontSize="16" Background="#33a5b0" Foreground="White" FontWeight="Bold" Width="125" Height="30"/>
        <Button Content="查询" Name="btnQuery"  Style="{StaticResource ButtonPrimary}"   Width="80" FontSize="16"  FontWeight="Bold" Height="30" Margin="517,37,0,0"  HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <DataGrid HeadersVisibility="All" 
  RowHeaderWidth="60" 
  AutoGenerateColumns="False" 
  ItemsSource="{Binding DataList}" Margin="0,83,0,0">

            <!-- 表头左侧：全选/单选框复选槽 -->
            <DataGrid.RowHeaderTemplate>
                <DataTemplate>
                    <CheckBox IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/>
                </DataTemplate>
            </DataGrid.RowHeaderTemplate>

            <!-- 列定义 -->
            <DataGrid.Columns>
                <!-- 序号/文本列 -->
                <DataGridTextColumn IsReadOnly="True" Width="80" CanUserResize="False" Binding="{Binding Index}" Header="序号"/>

                <!-- 图片列 -->
                <DataGridTemplateColumn Width="60" CanUserResize="False" Header="头像">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding ImgPath}" Width="32" Height="32" Stretch="Uniform"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- 文本列（撑满剩余空间） -->
                <DataGridTextColumn Width="100" Binding="{Binding Name}" Header="姓名"/>

                <!-- 复选框列 -->
                <DataGridCheckBoxColumn Width="100" CanUserResize="False" Binding="{Binding IsSelected}" Header="选择"/>

                <!-- 下拉框列 -->
                <!--<DataGridComboBoxColumn ItemsSource="{Binding Source={StaticResource DemoTypes}}" Width="100" CanUserResize="False" SelectedValueBinding="{Binding Type}" Header="类型"/>-->
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
