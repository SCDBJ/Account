<Page x:Class="Account.Views.IncomeCategory"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Account.Views"
      xmlns:Converter="clr-namespace:Account.Common"
      xmlns:hc="https://handyorg.github.io/handycontrol"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1500"
      Title="IncomeCategory" Loaded="Page_Loaded">

    <Page.Resources>
        <Converter:IsPositiveConverter x:Key="IsPositiveConverter"/>
        <Converter:AmountToHeightConverter x:Key="AmountToHeightConverter"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="收入分类：" VerticalAlignment="Center" FontSize="14" FontWeight="Bold"/>
            <hc:ComboBox Name="cboxIncomeCategory" Width="150" Height="30" SelectionChanged="cboxIncomeCategory_SelectionChanged">
                <ComboBoxItem Tag="1">全部</ComboBoxItem>
                <ComboBoxItem Tag="2">工资</ComboBoxItem>
                <ComboBoxItem Tag="3">年终奖</ComboBoxItem>
                <ComboBoxItem Tag="4">公积金</ComboBoxItem>
                <ComboBoxItem Tag="5" IsSelected="True">股票</ComboBoxItem>
                <ComboBoxItem Tag="6">个税退税</ComboBoxItem>
                <ComboBoxItem Tag="7">其他</ComboBoxItem>
            </hc:ComboBox>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="7*"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0" x:Name="incomeCategoryDataGrid" 
                      AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="All" RowHeaderWidth="40"
                      GridLinesVisibility="All" LoadingRow="DataGrid_LoadingRow" Margin="10">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="{x:Type DataGridColumnHeader}">
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="FontSize" Value="14"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Width="*" Binding="{Binding incomeDate}" Header="收入年月"/>
                    <DataGridTextColumn Width="*" Binding="{Binding categoryName}" Header="收入类型"/>
                    <DataGridTextColumn Width="*" Header="金额" Binding="{Binding incomeAmount}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding incomeAmount, Converter={StaticResource IsPositiveConverter}}" Value="False">
                                        <Setter Property="Foreground" Value="Green"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <DataGrid Grid.Column="1" x:Name="incomeYearCategoryDataGrid" 
                      AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="All" RowHeaderWidth="40"
                      GridLinesVisibility="All" LoadingRow="DataGrid_LoadingRow" Margin="10">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="{x:Type DataGridColumnHeader}">
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="FontSize" Value="14"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Width="*" Binding="{Binding incomeYear}" Header="收入年份"/>
                    <DataGridTextColumn Width="*" Binding="{Binding categoryName}" Header="收入类型"/>
                    <DataGridTextColumn Width="*" Header="金额" Binding="{Binding incomeAmount}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="Foreground" Value="Red"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding incomeAmount, Converter={StaticResource IsPositiveConverter}}" Value="False">
                                        <Setter Property="Foreground" Value="Green"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <ScrollViewer Grid.Column="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="10">

                <ItemsControl ItemsSource="{Binding IncomeList}" VerticalAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid VerticalAlignment="Bottom" HorizontalAlignment="Center" Width="60" Margin="2,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="400"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" VerticalAlignment="Bottom" HorizontalAlignment="Center">

                                    <TextBlock Text="{Binding IncomeAmount, StringFormat={}{0:N0}}" 
                           HorizontalAlignment="Center" 
                           FontSize="10" 
                           FontWeight="Bold" 
                           Margin="0,0,0,3" 
                           Foreground="#2196F3" TextWrapping="Wrap"/>

                                    <Border Width="20" CornerRadius="3,3,0,0" HorizontalAlignment="Center">
                                        <Border.Height>
                                            <MultiBinding Converter="{StaticResource AmountToHeightConverter}">
                                                <Binding Path="IncomeAmount"/>
                                                <Binding Path="DataContext.MaxAmount" RelativeSource="{RelativeSource AncestorType=Page}"/>
                                            </MultiBinding>
                                        </Border.Height>

                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#2196F3"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IncomeAmount, Converter={StaticResource IsPositiveConverter}}" Value="False">
                                                        <Setter Property="Background" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </StackPanel>
                                <TextBlock Grid.Row="1" Text="{Binding IncomeDate}" 
                       HorizontalAlignment="Center" Margin="0,8,0,20" Foreground="#666666" FontSize="10"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Row="2" Margin="10,10,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="5*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="10,0">
                <TextBlock FontSize="13" FontWeight="Bold" Text="天合计："/>
                <TextBlock x:Name="tblockSummary" FontWeight="Bold" FontSize="13" Foreground="DarkOrange"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0">
                <TextBlock FontSize="13" FontWeight="Bold" Text="年合计："/>
                <TextBlock x:Name="tblockYearSummary" FontWeight="Bold" FontSize="13" Foreground="DarkOrange"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>