<Page x:Class="Account.Views.IncomeCategory"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Account.Views"
      xmlns:Converter="clr-namespace:Account.Common"
      xmlns:hc="https://handyorg.github.io/handycontrol"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1000"
      Title="IncomeCategory" Loaded="Page_Loaded">
    <Page.Resources>
        <local:IsPositiveConverter x:Key="IsPositiveConverter"/>
    </Page.Resources>
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="15*"/>
            <RowDefinition Height="0.5*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="8*"/>
            <ColumnDefinition Width="4.5*"/>
            <ColumnDefinition Width="3.5*"/>
        </Grid.ColumnDefinitions>
        <hc:ComboBox Grid.Column="0"  Name="cboxIncomeCategory" HorizontalAlignment="Left" Margin="72,29,0,0" VerticalAlignment="Top" Width="100" SelectionChanged="cboxIncomeCategory_SelectionChanged">
            <ComboBoxItem Tag="1" >全部</ComboBoxItem>
            <ComboBoxItem Tag="2">工资</ComboBoxItem>
            <ComboBoxItem Tag="3" >年终奖</ComboBoxItem>
            <ComboBoxItem Tag="4" >公积金</ComboBoxItem>
            <ComboBoxItem Tag="5"  IsSelected="True">股票</ComboBoxItem>
            <ComboBoxItem Tag="6" >个税退税</ComboBoxItem>
            <ComboBoxItem Tag="7" >其他</ComboBoxItem>
        </hc:ComboBox>
        <DataGrid  Grid.Column="0" 
            x:Name="incomeCategoryDataGrid" 
            HorizontalAlignment="Left"
            HeadersVisibility="All" 
            RowHeaderWidth="60" 
            AutoGenerateColumns="False" 
            LoadingRow="DataGrid_LoadingRow"        
            IsReadOnly="True"
            Margin="50,83,0,38"
            GridLinesVisibility="All" 
            VerticalScrollBarVisibility="Auto"
            MaxHeight="{Binding Height, Source={x:Static SystemParameters.WorkArea}}">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="{x:Type DataGridColumnHeader}">
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="IsEnabled" Value="False"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <!-- 列定义 -->
            <DataGrid.Columns>
                <DataGridTextColumn Width="100" Binding="{Binding incomeDate}" Header="收入年月"/>
                <DataGridTextColumn Width="100" Binding="{Binding categoryName}" Header="收入类型"/>
                <DataGridTextColumn Width="100" Header="金额" Binding="{Binding incomeAmount}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="Red"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding incomeAmount, Converter={StaticResource IsPositiveConverter}}" Value="False">
                                    <Setter Property="Foreground" Value="Green"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
        <TextBlock Grid.Row="1" Grid.Column="0" FontSize="13" FontWeight="Bold" HorizontalAlignment="Left" Margin="50,0,0,0" TextWrapping="Wrap" Text="合计：" VerticalAlignment="Top"/>
        <TextBlock Grid.Row="1"  Grid.Column="0" x:Name="tblockSummary" FontWeight="Bold" FontSize="13" HorizontalAlignment="Left" Margin="180,0,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top"/>

    </Grid>
</Page>
