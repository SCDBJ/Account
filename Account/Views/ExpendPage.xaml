<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Account.Views"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      xmlns:hc="https://handyorg.github.io/handycontrol" 
      x:Class="Account.Views.ExpendPage"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ExpendPage" Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label Content="开始日期" HorizontalAlignment="Left" Margin="26,37,0,0" VerticalAlignment="Top" FontSize="16" Height="30"/>
        <hc:DatePicker Name="startDatePicker" SelectedDate="{x:Static sys:DateTime.Now}" hc:InfoElement.Placeholder="请选择日期" HorizontalAlignment="Left" Margin="130,37,0,0" FontSize="16" VerticalAlignment="Top" Background="#33a5b0" Foreground="White" FontWeight="Bold" Width="125" Height="30"/>
        <Label Content="结束日期" HorizontalAlignment="Left"  hc:InfoElement.Placeholder="请选择日期" Margin="265,37,0,0" VerticalAlignment="Top" FontSize="16" Height="30"/>
        <hc:DatePicker Name="endDatePicker"  SelectedDate="{x:Static sys:DateTime.Now}" HorizontalAlignment="Left" Margin="365,37,0,0" VerticalAlignment="Top" FontSize="16" Background="#33a5b0" Foreground="White" FontWeight="Bold" Width="125" Height="30"/>
        <Button Content="查询" Name="btnQuery" Click="btnQuery_Click" Style="{StaticResource ButtonPrimary}"   Width="80" FontSize="16"  FontWeight="Bold" Height="30" Margin="517,37,0,0"  HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Button Content="新增" x:Name="btnAdd" Click="btnAdd_Click" Style="{StaticResource ButtonSuccess}"   Width="80" FontSize="16"  FontWeight="Bold" Height="30" Margin="618,37,0,0"  HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <DataGrid Name="consumpDataGrid" 
          HorizontalAlignment="Left"
          HeadersVisibility="All" 
          RowHeaderWidth="60" 
          AutoGenerateColumns="False" 
          IsReadOnly="True"
          Margin="0,83,0,40"
          LoadingRow="DataGrid_LoadingRow" 
          GridLinesVisibility="All" >

            <!-- 表头左侧：全选/单选框复选槽 -->
            <DataGrid.RowHeaderTemplate>
                <DataTemplate>
                    <CheckBox IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}"/>
                </DataTemplate>
            </DataGrid.RowHeaderTemplate>
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="HorizontalContentAlignment" Value="Center"></Setter>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="IsEnabled" Value="False"></Setter>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <!-- 列定义 -->
            <DataGrid.Columns>
                <!-- 序号/文本列 -->
                <DataGridTextColumn IsReadOnly="True" Width="50" CanUserResize="False" Binding="{Binding Header, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}, Mode=FindAncestor}}" Header="序号"/>

                <!-- 图片列 -->
                <DataGridTemplateColumn Width="60" Visibility="Collapsed" CanUserResize="False" Header="consumpId">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding consumpId}" Width="32" Height="32" Stretch="Uniform"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Width="80" Binding="{Binding categoryName}" Header="支出类型"/>
                <DataGridTextColumn Width="80" Binding="{Binding consumpAmount}" Header="支出金额"/>
                <DataGridTextColumn Width="160" Binding="{Binding consumpTime, StringFormat='yyyy-MM-dd HH:mm:ss'}" Header="支出时间"/>
                <DataGridTextColumn Width="160" Binding="{Binding createTime, StringFormat='yyyy-MM-dd HH:mm:ss'}" Header="创建时间"/>
                <DataGridTemplateColumn Width="130"  Header="备注">
                    <!-- 1. 日常浏览状态（只读） -->
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <!-- 直接在这里对真正的 TextBlock 设置属性，没有任何中间商赚差价 -->
                            <TextBlock Text="{Binding consumpNote}" 
                               TextWrapping="Wrap" 
                               Padding="5,8" 
                               VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>

                    <!-- 2. 双击编辑状态（可选，如果不需要编辑可以不写） -->
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <!-- 编辑时使用 TextBox，同样支持换行 -->
                            <TextBox Text="{Binding consumpNote, UpdateSourceTrigger=PropertyChanged}" 
                             TextWrapping="Wrap" 
                             AcceptsReturn="True"
                             VerticalContentAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="操作" Width ="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Height="45">
                                <Button x:Name="btnDelete" Margin="35,0,10,10" HorizontalAlignment="Center" VerticalAlignment="Center" VerticalContentAlignment="Center" Content="删除" Width="80" Height="30"  FontSize="13" Click="btnDelete_Click"  Background="#1C86EE" Foreground="White"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <TextBlock Grid.Row="1" FontSize="13" FontWeight="Bold" HorizontalAlignment="Left" Margin="30,0,0,0" TextWrapping="Wrap" Text="合计：" VerticalAlignment="Top"/>
        <TextBlock Grid.Row="1" x:Name="tblockSummary" FontWeight="Bold" FontSize="13" HorizontalAlignment="Left" Margin="207,0,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top"/>

    </Grid>
</Page>
