<Page x:Class="Account.Views.SalaryDetail"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Account.Views"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1500"
      Title="SalaryDetail"  Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="15*"/>
            <RowDefinition Height="0.5*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="21*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>
        <DataGrid  Grid.Column="0" Grid.Row="0"
Name="SalaryDatagrid" 
HorizontalAlignment="Left"
HeadersVisibility="All" 
RowHeaderWidth="60" 
AutoGenerateColumns="False" 
LoadingRow="DataGrid_LoadingRow" 
IsReadOnly="True"
Margin="0,70,0,10"
GridLinesVisibility="All" 
VerticalScrollBarVisibility="Auto"
MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="HorizontalContentAlignment" Value="Center"></Setter>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="IsEnabled" Value="False"></Setter>
                    <Setter Property="ContentTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <!-- 列定义 -->
            <DataGrid.Columns>
                <!-- 序号/文本列 -->
                <!--<DataGridTextColumn IsReadOnly="True" Width="50" CanUserResize="False" Binding="{Binding Header, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}, Mode=FindAncestor}}" Header="序号"/>-->

                <DataGridTemplateColumn Width="60" Visibility="Collapsed" CanUserResize="False" Header="incomeId">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding incomeId}" Width="32" Height="32" Stretch="Uniform"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Width="60" Binding="{Binding datacyear}" Header="年度"/>
                <DataGridTextColumn Width="50" Binding="{Binding datacperiod}" Header="期间"/>
                <DataGridTextColumn Width="90" Binding="{Binding dataf_32}" Header="核定工资总额"/>
                <DataGridTextColumn Width="90" Binding="{Binding dataf_40}" Header="基本工资"/>
                <DataGridTextColumn Width="90" Binding="{Binding dataf_94}" Header="核定绩效奖金"/>
                <DataGridTextColumn Width="90" Binding="{Binding dataf_95}" Header="绩效奖金"/>
                <DataGridTextColumn Width="90" Binding="{Binding dataf_96}" Header="绩效奖金差异"/>
                <DataGridTextColumn Width="90" Binding="{Binding dataf_97}" Header="绩效奖金差异(%)"/>
                <DataGridTextColumn Width="90" Binding="{Binding dataf_63}" Header="税前扣款合计"/>
                <DataGridTextColumn Width="90" Binding="{Binding dataf_79}" Header="应付工资"/>
                <DataGridTextColumn Width="90" Binding="{Binding dataf_158}" Header="社保个人合计"/>
                <DataGridTextColumn Width="90" Binding="{Binding dataf_5}" Header="本次扣税"/>
                <DataGridTextColumn Width="90" Binding="{Binding dataf_157}" Header="社保单位合计"/>
                <DataGridTextColumn Width="90" Binding="{Binding dataf_3}" Header="实发合计"/>
                <DataGridTextColumn Width="90" Binding="{Binding dataf_163}" Header="扣减合计(不含公积金)"/>
            </DataGrid.Columns>
        </DataGrid>
        <TextBlock Grid.Row="1" Grid.Column="0" FontSize="13" FontWeight="Bold" HorizontalAlignment="Left" Margin="30,0,0,0" TextWrapping="Wrap" Text="合计：" VerticalAlignment="Top"/>
        <TextBlock Grid.Column="0" Grid.Row="1" x:Name="sumdataf_32" HorizontalAlignment="Left" Margin="160,0,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" TextAlignment="Center" FontSize="13" Height="31" Width="108"  />
        <TextBlock Grid.Column="0" Grid.Row="1" x:Name="sumdataf_3" HorizontalAlignment="Left" Margin="1160,0,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" TextAlignment="Center" FontSize="13" Height="31" Width="108"  />
        <TextBlock Grid.Column="0" Grid.Row="1" x:Name="sumdataf_163" HorizontalAlignment="Left" Margin="1245,0,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" TextAlignment="Center" FontSize="13" Height="31" Width="108"  />

    </Grid>
</Page>
